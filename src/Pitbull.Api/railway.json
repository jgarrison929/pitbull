{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "src/Pitbull.Api/Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "healthcheckPath": "/health/live",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE"
  }
}