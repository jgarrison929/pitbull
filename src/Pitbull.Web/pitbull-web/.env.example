# =============================================================================
# Pitbull Web (Next.js) - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#
# NEXT_PUBLIC_ prefix = exposed to the browser (client-side code).
# Without the prefix = server-side only (API routes, SSR).
#
# NEXT_PUBLIC_ vars are baked into the JS bundle at `next build` time.
# =============================================================================

# -----------------------------------------------------------------------------
# API Connection
# -----------------------------------------------------------------------------

# Base URL for the Pitbull API (no trailing slash)
# Local dev: http://localhost:5081 (see src/Pitbull.Api launchSettings.json)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5081

# -----------------------------------------------------------------------------
# Next.js Runtime
# -----------------------------------------------------------------------------

# Port the dev server / standalone server listens on (default: 3000)
PORT=3000

# Node environment (development | production | test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostHog Analytics (optional — client-side key, safe to expose in browser)
# -----------------------------------------------------------------------------
# Set at BUILD TIME on Railway/production. Do not commit .env.production.
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
